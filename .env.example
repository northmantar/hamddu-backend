# ── Infisical bootstrap ──────────────────────────────────────────────────────
# These are the ONLY vars needed locally. All other secrets come from Infisical.
INFISICAL_SITE_URL=http://localhost:80
INFISICAL_PROJECT_ID=your-project-id
INFISICAL_ENVIRONMENT=dev

# Option A — Machine Identity (Universal Auth)
# INFISICAL_CLIENT_ID=your-client-id
# INFISICAL_CLIENT_SECRET=your-client-secret

# Option B — Access Token (use this OR Option A, not both)
INFISICAL_ACCESS_TOKEN=your-access-token