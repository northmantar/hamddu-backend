# ── Infisical bootstrap ──────────────────────────────────────────────────────
# These are the ONLY vars needed locally. All other secrets come from Infisical.
INFISICAL_SITE_URL=http://localhost:80
INFISICAL_PROJECT_ID=your-project-id
INFISICAL_ENVIRONMENT=dev

# Option A — Machine Identity (Universal Auth)
# INFISICAL_CLIENT_ID=your-client-id
# INFISICAL_CLIENT_SECRET=your-client-secret

# Option B — Access Token (use this OR Option A, not both)
INFISICAL_ACCESS_TOKEN=your-access-token

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Manage at: Cloudflare Dashboard → R2 → your bucket → Settings
# R2_ACCOUNT_ID   : Cloudflare account ID (found in dashboard URL)
# R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY : R2 API token (R2 read & write)
# R2_BUCKET_NAME  : R2 bucket name (e.g. hamddu-media)
# CDN_BASE_URL    : Public URL for the bucket (custom domain or r2.dev preview URL)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=hamddu-media
CDN_BASE_URL=https://cdn.hamddu.online
