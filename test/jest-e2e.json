{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@entities/(.*)$": "<rootDir>/src/entities/$1",
    "^@enums/(.*)$": "<rootDir>/src/enums/$1",
    "^@dto/(.*)$": "<rootDir>/src/dto/$1"
  }
}
